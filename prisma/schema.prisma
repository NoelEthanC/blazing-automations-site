// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  resources         Resource[]
  watchUsBuildVideos WatchUsBuildVideo[]
  leads             Lead[]

  @@map("users")
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  longDescription String? @db.LongText
  thumbnail   String?
  filePath    String?
  fileType    String?
  tool        String?
  category    ResourceCategory @default(TEMPLATE)
  hasGuide    Boolean  @default(false)
  guideUrl    String?
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  downloadsCount Int   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  downloads ResourceDownload[]

  @@map("resources")
}

model ResourceDownload {
  id         String   @id @default(cuid())
  email      String
  action     DownloadAction
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  // Relations
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@map("resource_downloads")
}

model WatchUsBuildVideo {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  videoUrl    String
  thumbnail   String?
  duration    String?
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  viewsCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("watch_us_build_videos")
}

model Lead {
  id        String   @id @default(cuid())
  email     String
  name      String?
  company   String?
  message   String?  @db.Text
  source    LeadSource
  status    LeadStatus @default(NEW)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  @@map("leads")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String   @db.Text
  status    ContactStatus @default(NEW)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_submissions")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ResourceCategory {
  TEMPLATE
  GUIDE
  TOOL
  EBOOK
}

enum DownloadAction {
  DOWNLOAD
  EMAIL
}

enum LeadSource {
  CONTACT_FORM
  RESOURCE_DOWNLOAD
  NEWSLETTER
  CALENDLY
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
}

enum ContactStatus {
  NEW
  REPLIED
  CLOSED
}
